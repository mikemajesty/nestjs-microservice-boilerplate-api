{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: App",
      "type": "node",
      "request": "launch",
      "restart": true,
      "skipFiles": ["<node_internals>/**"],
      "console": "integratedTerminal",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run-script", "start:debug"]
    },
    {
      "name": "Run Mongo Migration",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "migration-mongo:run"],
      "console": "integratedTerminal"
    },
    {
      "name": "Run Mongo Migration Rollback",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "migration-mongo:rollback"],
      "console": "integratedTerminal"
    },
    {
      "name": "Run Mongo Migration Status",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "migration-mongo:status"],
      "console": "integratedTerminal"
    }
  ]
}
